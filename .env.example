# ═══════════════════════════════════════════════════════════════════════════════
# Launchpad Boilerplate — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy: cp .env.example .env
# Fill in required values before running.
#
# Claude Code Phase 0 (Foundation) will ADD stack-specific variables below
# based on your project/TECH-STACK.md. These are the common defaults.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────

# Environment: development | production | test
APP_ENV=development

# Application name (used in logs, emails, etc.)
APP_NAME=MyApp

# Backend port
APP_PORT=4000

# Frontend port (if separate frontend app)
WEB_PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────

# Connection string (default matches infra/docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# Docker Compose settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_dev
POSTGRES_PORT=5432

# ── Redis (uncomment if using caching / queues) ─────────────────────────────

# REDIS_URL=redis://localhost:6379
# REDIS_PORT=6379

# ── Authentication (uncomment if using auth) ─────────────────────────────────

# JWT secrets — MUST be different, min 32 random chars
# Generate: openssl rand -base64 32
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# ── Email (uncomment if using transactional email) ───────────────────────────

# RESEND_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# ── Payments (uncomment if using Stripe) ─────────────────────────────────────

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── File Storage (uncomment if using uploads) ────────────────────────────────

# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Phase 0 inserts stack-specific variables below this line.
# ═══════════════════════════════════════════════════════════════════════════════
