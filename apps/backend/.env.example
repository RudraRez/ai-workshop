NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Groq — used for chat, flashcards, and audio-overview scripts
# Get a free key at https://console.groq.com/keys (no billing required)
# Free tier: 14,400 requests/day on llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1    # override only if self-hosting

# Audio Overview TTS — uses Google Translate's public TTS endpoint.
# No API key required. Text is chunked to ~180 chars per request and
# the MP3 buffers are concatenated. Unofficial; rate-limited by IP.

# Where generated audio MP3s are saved (relative to backend cwd)
UPLOAD_DIR=./uploads

# Postgres (not required for MVP — endpoints use in-memory storage)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
