NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Google AI (Gemini + Text-to-Speech) — single key, enable both APIs in GCP
# Rotate the key if it has ever appeared in chat, logs, or a commit
GOOGLE_API_KEY=

# Gemini model used for chat + flashcard generation
GEMINI_MODEL=gemini-2.5-flash

# Where generated audio MP3s are saved (relative to backend cwd)
UPLOAD_DIR=./uploads

# Postgres (not required for MVP — endpoints use in-memory storage)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
